POSTGRES_DB=recon
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
RECON_DB=Host=postgres;Port=5432;Database=recon;Username=postgres;Password=postgres
RECON_PIPELINE_PROVIDER=Simulated
RECON_INSTALL_COLMAP=false
RECON_COLMAP_REF=3.13.0
RECON_COLMAP_CUDA_ARCHITECTURES=75;80;86;89
RECON_COLMAP_BINARY_PATH=colmap
RECON_COLMAP_USE_GPU=true
RECON_STORAGE_ROOT=/var/recon/storage
RECON_SCRATCH_ROOT=/tmp/recon
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility,graphics
XDG_RUNTIME_DIR=/tmp/runtime-root
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
