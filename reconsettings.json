    "ObjectStorageAccessKey": "minioadmin",
    "ObjectStorageSecretKey": "minioadmin",
    "ObjectStorageUseSsl": false,
    "PipelineProvider": "Colmap",
    "ColmapBinaryPath": "colmap",
    "ColmapUseGpu": true,
    "WorkerIdlePollSeconds": 5,
    "StorageRootPath": "/var/recon/storage",
    "ScratchRootPath": "/tmp/recon",
    "PipelineVersion": "colmap"
  }
}
